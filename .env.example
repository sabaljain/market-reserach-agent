# LangSmith Observability (optional — remove or set to false to disable)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=market-research-agent
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # default, only set if self-hosting

# Search backend selection: "openserp" (default) or "tavily" (fallback)
SEARCH_PROVIDER=openserp

# Tavily Search API (only required when SEARCH_PROVIDER=tavily)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenSERP self-hosted endpoint (used when SEARCH_PROVIDER=openserp)
# Start the container first: docker compose -f docker-compose.openserp.yml up -d
OPENSERP_URL=http://localhost:7000

# Azure OpenAI — Discovery node (GPT-4.1-mini)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_KEY=<your-azure-openai-key>
AZURE_API_VERSION=2024-02-01
AZURE_DEPLOYMENT_DISCOVERY=gpt-4.1-mini

# Azure OpenAI — Profiler + Synth nodes (GPT-5 or other high-quality model, separate endpoint)
AZURE_OPENAI_PROFILER_ENDPOINT=https://<your-other-resource>.openai.azure.com
AZURE_OPENAI_PROFILER_KEY=<your-profiler-azure-openai-key>
AZURE_PROFILER_API_VERSION=2024-02-01
AZURE_DEPLOYMENT_PROFILER=gpt-5
AZURE_DEPLOYMENT_SYNTH=gpt-5
AZURE_DEPLOYMENT_WRITER=gpt-5
